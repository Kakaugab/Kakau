using System;
class Program
{
    static void Main(string[] args)
    {
        int[] vet = new int[5];
        for (int i = 0; i < 5; i++)
        { 
            Console.WriteLine("Digite um número: ");
            vet[i] = int.Parse(Console.ReadLine());
        }
        Array.Sort(vet);
        Console.WriteLine("Números em ordem crescente: ");
        foreach (int i in vet)
        {
            Console.WriteLine(i);
        }
    }
} 

