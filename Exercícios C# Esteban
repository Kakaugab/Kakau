using System;

class Program 
{
    static void Main() 
   {
        int n = int.Parse(Console.ReadLine());
        int c = 0, r = 0, s = 0;

        for (int i = 0; i < n; i++) 
      {

            string[] v = Console.ReadLine().Split(' ');
            int qtd = int.Parse(v[0]);
            char tipo = char.Parse(v[1]);

            if (tipo == 'C') c += qtd;
            else if (tipo == 'R') r += qtd;
            else if (tipo == 'S') s += qtd;
        }

        int total = c + r + s;

        Console.WriteLine($"Total: {total} cobaias");
        Console.WriteLine($"Total de coelhos: {c}");
        Console.WriteLine($"Total de ratos: {r}");
        Console.WriteLine($"Total de sapos: {s}");
        Console.WriteLine($"Percentual de coelhos: {(c*100.0/total):F2} %");
        Console.WriteLine($"Percentual de ratos: {(r*100.0/total):F2} %");
        Console.WriteLine($"Percentual de sapos: {(s*100.0/total):F2} %");
    }
} 

