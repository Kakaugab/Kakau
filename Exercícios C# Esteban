  {
        int n = int.Parse(Console.ReadLine());

        for (int i = 0; i < n; i++) 
       {
            int x = int.Parse(Console.ReadLine());
            bool primo = true;

            if (x < 2) primo = false;

            for (int j = 2; j*j <= x; j++)
                if (x % j == 0) 
                {
                    primo = false;
