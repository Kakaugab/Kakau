using System;

class Program
{
    static void Main(string[] args)
    {
        Console.WriteLine("Digite o valor de A:");
        if (!int.TryParse(Console.ReadLine(), out int A) || A <= 0)
        {
            Console.WriteLine("Valor inválido para A.");
            return;
        }

        Console.WriteLine("Digite o valor de B:");
        if (!int.TryParse(Console.ReadLine(), out int B) || B <= 0)
        {
            Console.WriteLine("Valor inválido para B.");
            return;
        }

        Console.WriteLine("Digite o valor de C:");
        if (!int.TryParse(Console.ReadLine(), out int C) || C <= 0)
        {
            Console.WriteLine("Valor inválido para C.");
            return;
        }

        double R = Math.Pow(A + B, 2);
        double S = Math.Pow(B + C, 2);
        double D = (R + S) / 2;

        Console.WriteLine($"O valor de R é: {R}");
        Console.WriteLine($"O valor de S é: {S}");
        Console.WriteLine($"O valor de D é: {D}");
    }
}


