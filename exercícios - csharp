using System;

class Program
{
    static void Main(string[] args)
    {
        double nota1, nota2, nota3;
        int peso1 = 2, peso2 = 3, peso3 = 5;

        Console.WriteLine("Digite a primeira nota:");
        if (!double.TryParse(Console.ReadLine(), out nota1))
        {
            Console.WriteLine("Nota inválida.");
            return;
        }

        Console.WriteLine("Digite a segunda nota:");
        if (!double.TryParse(Console.ReadLine(), out nota2))
        {
            Console.WriteLine("Nota inválida.");
            return;
        }

        Console.WriteLine("Digite a terceira nota:");
        if (!double.TryParse(Console.ReadLine(), out nota3))
        {
            Console.WriteLine("Nota inválida.");
            return;
        }

        double mediaFinal = ((nota1 * peso1) + (nota2 * peso2) + (nota3 * peso3)) / (peso1 + peso2 + peso3);

        Console.WriteLine("A média final do aluno é: {mediaFinal:F2}");
    }
}

